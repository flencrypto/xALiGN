# ContractGHOST Environment Configuration
# Copy this file to .env and fill in your values

# ── Backend ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./contractghost.db
# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/contractghost

CORS_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── Optional: AI / LLM Integration ──────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...
GROK_API_KEY=your_grok_api_key_here
UPLOAD_DIR=./uploads

# ── Optional: S3 (if not set, files stored locally) ───────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# ── Optional: Auth ────────────────────────────────────────────────────────────
# CLERK_SECRET_KEY=...
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=...
