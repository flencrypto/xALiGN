# aLiGN Environment Configuration
# Copy this file to .env and fill in your values

# ── Backend ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./align.db
# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/align

CORS_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── Optional: AI / LLM Integration ──────────────────────────────────────────
# XAI_API_KEY=xai-...              (Grok – required for Intelligence & Blog features)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...

# ── File Storage ─────────────────────────────────────────────────────────────
# STORAGE_BACKEND=local            (default: local filesystem)
# STORAGE_BACKEND=s3               (production: Amazon S3)
# UPLOAD_DIR=./uploads             (local storage path)
#
# When STORAGE_BACKEND=s3, set these:
# S3_BUCKET=your-bucket-name
# S3_REGION=eu-west-2
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# ── Auth (SSO) ────────────────────────────────────────────────────────────────
# AUTH_PROVIDER=none               (default – auth disabled, open access)
# AUTH_PROVIDER=clerk              (Clerk JWT verification)
# AUTH_PROVIDER=auth0              (Auth0 JWT verification)
#
# Clerk:
# CLERK_ISSUER=https://your-clerk-instance.clerk.accounts.dev
# CLERK_JWKS_URL=                  (optional; derived from CLERK_ISSUER if blank)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
# CLERK_SECRET_KEY=sk_...
#
# Auth0:
# AUTH0_DOMAIN=your-tenant.auth0.com
# AUTH0_AUDIENCE=https://your-api-audience
# NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.auth0.com
# NEXT_PUBLIC_AUTH0_CLIENT_ID=...

# ── AI Governance ────────────────────────────────────────────────────────────
# AI_CONFIDENCE_THRESHOLD=0.65      (suppress outputs below this, default 0.65)
# AI_REVIEW_THRESHOLD=0.5           (flag for human review below this, default 0.5)
# AI_FALLBACK_MODEL=grok-3-mini     (fallback model when primary confidence low)
# AI_MAX_CONTRACT_VALUE_GBP=10000000000  (anomaly flag threshold, default £10bn)
# AI_MAX_CAPEX_GROWTH_PCT=500       (anomaly flag threshold, default 500%)
