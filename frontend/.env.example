# Frontend Environment Variables for Vercel Deployment
# Copy this file to .env.local for local development

# ── Backend API Configuration ──────────────────────────────────────────────
# Point to your deployed backend API (FastAPI)
# For Vercel preview: Use your Railway/Render/fly.io backend URL
# For production: Use your production backend URL
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── Clerk Authentication ───────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk Issuer and JWKS (auto-detected from publishable key, but can override)
CLERK_ISSUER=https://your-app.clerk.accounts.dev
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json

# Clerk Sign-in/Sign-up Routes (required for proper redirects)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Clerk Redirect URLs (after successful auth)
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ── Build Configuration ────────────────────────────────────────────────────
# Leave unset for Vercel (or set to false)
# DOCKER_BUILD=false
